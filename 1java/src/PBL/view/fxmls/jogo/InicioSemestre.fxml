<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="PBL.view.TransicaoSemestreView">
    <children>
        <StackPane id="stackPrincipal" fx:id="stackPrincipal" alignment="CENTER_RIGHT" nodeOrientation="LEFT_TO_RIGHT" prefHeight="720.0" prefWidth="1280.0" styleClass="stack-sem-overflow" stylesheets="@../../estilo.css">
            <children>
                <ImageView id="imagemFundo" fx:id="imagemFundo" fitHeight="720.0" fitWidth="1280.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../../../resources/background/FundoPreto.png" />
                    </image>
                </ImageView>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="200.0" prefWidth="637.0" StackPane.alignment="CENTER">
               <children>
                  <ImageView fitHeight="150.0" fitWidth="500.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../../../resources/CompLifeTitulo.png" />
                     </image>
                  </ImageView>
                  <Label fx:id="labelSemestre" alignment="CENTER" lineSpacing="4.0" text="1° Semestre do Curso de Engenharia de Computação" textAlignment="CENTER" textFill="WHITE" wrapText="true">
                     <font>
                        <Font name="Press Start 2P" size="25.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            </children>
        </StackPane>
    </children>
</AnchorPane>
